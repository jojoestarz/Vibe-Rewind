# Copy to .env in the repo root (same folder as package.json).

# Supabase (required for persistence)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret

# Gemini batch scoring at session end (required for real scores; Google AI Studio API key)
GEMINI_API_KEY=
# Optional: override default model (gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# Optional: viewer / API port when running `npm start`
# PROMPTLOG_PORT=3000

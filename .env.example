# Copy to .env in the repo root (same folder as package.json).

# Supabase (required for persistence)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret

# Claude batch scoring at session end (required for real scores)
ANTHROPIC_API_KEY=

# Optional: viewer / API port when running `npm start`
# PROMPTLOG_PORT=3000
